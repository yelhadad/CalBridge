{
  "version": "1.00",
  "logging_version": 1,
  "disable_existing_loggers": false,
  "formatters": {
    "json": {
      "format": "{\"time\": \"%(asctime)s\", \"level\": \"%(levelname)s\", \"logger\": \"%(name)s\", \"message\": \"%(message)s\"}",
      "datefmt": "%Y-%m-%dT%H:%M:%S"
    }
  },
  "handlers": {
    "console": {
      "class": "logging.StreamHandler",
      "level": "INFO",
      "formatter": "json",
      "stream": "ext://sys.stderr"
    }
  },
  "loggers": {
    "apple_sync": {
      "level": "DEBUG",
      "handlers": ["console"],
      "propagate": false
    }
  },
  "root": {
    "level": "WARNING",
    "handlers": ["console"]
  }
}
